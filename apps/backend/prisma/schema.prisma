generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum Role {
  ADMIN
  MEMBER
  GUEST
}

enum MembershipRole {
  OWNER
  ADMIN
  STAFF
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  DEBT
}

enum ScheduleMode {
  FIXED
  RANGE
}

enum FixedBookingStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

//
// MODELOS
//

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  firstName     String
  lastName      String
  phoneNumber   String
  role          Role           @default(MEMBER)
  isProfessor   Boolean        @default(false)
  dni       String?

  bookings      Booking[]
  fixedBookings FixedBooking[]
  cashMovements CashMovement[]
  memberships   Membership[]
  payments      Payment[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model Club {
  id           Int       @id @default(autoincrement())
  slug         String    @unique
  name         String
  addressLine  String
  city         String
  province     String
  country      String

  locationId   Int?
  location     Location? @relation(fields: [locationId], references: [id])

  contactInfo  String
  phone        String?
  logoUrl      String?
  clubImageUrl String?
  instagramUrl String?
  facebookUrl  String?
  websiteUrl   String?
  description  String?

  // Zona horaria IANA obligatoria
  timeZone     String    @default("America/Argentina/Buenos_Aires")

  lightsEnabled          Boolean @default(false)
  lightsExtraAmount      Float?
  lightsFromHour         String?

  // Días de apertura: array de enteros (0 Domingo .. 6 Sábado)
  openingDays            Json?

  professorDiscountEnabled Boolean @default(false)
  professorDiscountPercent Float?

  fixedBookingSettingsByActivity Json?

  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)

  courts        Court[]
  activities    ActivityType[]
  bookings      Booking[]
  products      Product[]
  cashMovements CashMovement[]
  memberships   Membership[]
  fixedBookings FixedBooking[]
  payments      Payment[]
  notifications Notification[]
  courtPriceRules CourtPriceRule[]
  auditLogs     AuditLog[]
  events        Event[]
  settings      ClubSettings?
}

model Membership {
  id     String         @id @default(cuid())
  userId Int
  clubId Int
  role   MembershipRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, clubId])
  @@index([clubId])
  @@index([userId])
}

model Location {
  id        Int      @id @default(autoincrement())
  city      String
  province  String
  country   String

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  clubs     Club[]

  @@unique([city, province, country])
}

model Court {
  id                 Int     @id @default(autoincrement())
  name               String
  isIndoor           Boolean
  surface            String
  isUnderMaintenance Boolean @default(false)
  price              Float   @default(0)

  activityTypeId Int?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id])

  clubId Int
  club   Club @relation(fields: [clubId], references: [id])

  bookings      Booking[]
  fixedBookings FixedBooking[]
  priceRules    CourtPriceRule[]

  @@index([clubId])
}

model CourtPriceRule {
  id           Int      @id @default(autoincrement())

  courtId      Int
  court        Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  clubId       Int
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  dayOfWeek    Int
  startMinutes Int
  endMinutes   Int
  price        Float

  createdAt    DateTime @default(now()) @db.Timestamptz(3)

  @@index([courtId])
  @@index([clubId])
  @@index([courtId, dayOfWeek])
}

model ActivityType {
  id                     Int            @id @default(autoincrement())
  name                   String
  description            String
  defaultDurationMinutes Int

  clubId                 Int
  club                   Club           @relation(fields: [clubId], references: [id])

  scheduleMode           ScheduleMode   @default(FIXED)
  scheduleOpenTime       String?
  scheduleCloseTime      String?
  scheduleIntervalMinutes Int?
  scheduleDurations      Json?
  scheduleFixedSlots     Json?

  courts                 Court[]
  bookings               Booking[]
  fixedBookings          FixedBooking[]

  @@index([clubId])
}

model Booking {
  id              Int           @id @default(autoincrement())

  startDateTime   DateTime      @db.Timestamptz(3)
  endDateTime     DateTime      @db.Timestamptz(3)

  cancelledBy     Int?
  cancelledAt     DateTime?     @db.Timestamptz(3)

  price           Float
  createdAt       DateTime      @default(now()) @db.Timestamptz(3)

  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)

  guestIdentifier String?
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  guestDni        String?

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  courtId Int
  court   Court @relation(fields: [courtId], references: [id])

  activityId Int
  activity   ActivityType @relation(fields: [activityId], references: [id])

  clubId Int
  club   Club @relation(fields: [clubId], references: [id])

  fixedBookingId Int?
  fixedBooking   FixedBooking? @relation(fields: [fixedBookingId], references: [id])

  items          BookingItem[]
  cashMovements  CashMovement[]
  payments       Payment[]

  @@index([courtId, startDateTime], map: "booking_court_day")
  @@index([courtId, endDateTime])
  @@index([clubId, startDateTime], map: "booking_club_day")
  @@index([activityId, startDateTime], map: "booking_activity_day")
  @@index([startDateTime])
}

model FixedBooking {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  dayOfWeek Int
  startTimeMinutes Int
  endTimeMinutes   Int
  startDate DateTime @db.Timestamptz(3)

  status     FixedBookingStatus @default(ACTIVE)
  guestPhone String?
  guestDni   String?
  guestName  String?

  userId     Int?
  user       User? @relation(fields: [userId], references: [id])

  courtId    Int
  court      Court @relation(fields: [courtId], references: [id])

  activityId Int
  activity   ActivityType @relation(fields: [activityId], references: [id])

  clubId Int
  club   Club @relation(fields: [clubId], references: [id])

  bookings Booking[]

  @@index([courtId, dayOfWeek])
  @@index([clubId])
}

model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  amount    Decimal  @db.Decimal(10, 2)
  method    String
  status    PaymentStatus @default(PENDING)

  bookingId Int?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Restrict)

  @@index([clubId])
  @@index([clubId, createdAt])
  @@index([bookingId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  title     String
  message   String
  channel   String?
  isRead    Boolean  @default(false)
  status    String?
  sentAt    DateTime? @db.Timestamptz(3)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Restrict)

  @@index([clubId])
  @@index([clubId, createdAt])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())

  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id])

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])

  entity    String
  entityId  String
  action    String
  payload   Json?

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([clubId])
  @@index([entity, entityId])
}

model Event {
  id        String   @id @default(cuid())

  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id])

  type      String
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  processed Boolean  @default(false)

  @@index([clubId])
  @@index([type])
}

model ClubSettings {
  id                         Int      @id @default(autoincrement())

  clubId                     Int      @unique
  club                       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  timeZone                   String
  openingDays                Json?

  lightsEnabled              Boolean
  lightsExtraAmount          Float?
  lightsFromHour             Int?

  professorDiscountEnabled   Boolean
  professorDiscountPercent   Float?

  createdAt                  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt                  DateTime @updatedAt @db.Timestamptz(3)
}

model Product {
  id       Int     @id @default(autoincrement())
  name     String
  category String?
  price    Decimal @db.Decimal(10, 2)
  stock    Int     @default(0)
  isCombo  Boolean @default(false)
  minStock Int     @default(5)
  isActive Boolean @default(true)

  clubId Int
  club   Club @relation(fields: [clubId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  bookingItems BookingItem[]
  components  ProductComponent[] @relation("ComboParent")
  usedInCombos ProductComponent[] @relation("ComboComponent")

  @@index([clubId])
}

model ProductComponent {
  id Int @id @default(autoincrement())

  parentProductId Int
  parentProduct Product @relation("ComboParent", fields: [parentProductId], references: [id], onDelete: Cascade)

  componentProductId Int
  componentProduct Product @relation("ComboComponent", fields: [componentProductId], references: [id], onDelete: Cascade)

  quantity Int

  @@unique([parentProductId, componentProductId])
  @@index([parentProductId])
  @@index([componentProductId])
}

model BookingItem {
  id Int @id @default(autoincrement())

  bookingId Int
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Float
  paymentMethod String?
}

model CashMovement {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now()) @db.Timestamptz(3)

  type        String
  amount      Float
  description String
  method      String

  bookingId Int?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  guestName  String?
  guestPhone String?
  guestDni   String?

  isSettled  Boolean @default(true)

  clubId Int
  club   Club @relation(fields: [clubId], references: [id])

  @@index([clubId, date])
  @@index([clubId, userId])
}